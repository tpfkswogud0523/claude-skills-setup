# Local machine configuration template.
# Copy to .env on each computer and fill in local values.
# Do not commit real secrets.

# GitHub
GITHUB_TOKEN=
GITHUB_DEFAULT_OWNER=
GITHUB_DEFAULT_REPO=

# Sentry
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_BASE_URL=https://sentry.io
SENTRY_ENVIRONMENT=production
SENTRY_AUTO_CREATE_GITHUB_ISSUES=false
SENTRY_EVENT_THRESHOLD=

# Firecrawl
FIRECRAWL_API_KEY=

# Obsidian
# Example:
# OBSIDIAN_VAULT_PATH=C:\Users\user\OneDrive\Documents\Obsidian Vault
OBSIDIAN_VAULT_PATH=

# Optional shared note locations
NOTION_WORKSPACE=
AI_WORK_LOG_LOCATION=
